{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.3.1",
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "templates/**"
    },
    "api/scrape.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    }
  }
}
