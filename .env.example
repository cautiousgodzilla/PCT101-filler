# Copy to .env (local) or set in your host's environment variables.

# Google Gemini (extraction)
GEMINI_API_KEY=your_google_gemini_api_key_here

# --- Supabase auth (optional) ---
# If these are unset, authentication is DISABLED and the app stays open.
# Set all three to require login. SUPABASE_SECRET_KEY is server-only — it is
# NEVER sent to the browser (only the URL + anon key are exposed via /api/config).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
SUPABASE_SECRET_KEY=your_supabase_service_role_key

# --- Firm/agent config (optional) ---
# Per-firm details + agent roster, matched to a user's login-email domain.
# Locally this is read from firm_config.json. On hosts like Render where that
# git-ignored file isn't deployed, set FIRM_CONFIG_JSON to the SAME JSON, minified
# to one line. (env var takes precedence over the file.)
# FIRM_CONFIG_JSON={"firms":[{"domains":["yourfirm"],"firm_name":"...","agents":[...]}]}
