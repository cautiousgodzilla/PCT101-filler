# ─────────────────────────────────────────────────────────────
# Secrets & environment  (NEVER commit these)
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
secrets.json
service-account*.json

# Firm / agent PII — the REAL templates and firm details stay private.
# (Public repo ships firm-redacted templates/ + firm_details.example.json only.)
templates_private/
firm_details.json
!firm_details.example.json
firm_config.json
!firm_config.example.json

